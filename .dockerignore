# Git
.git                    # Git repository metadata
.gitignore              # Git ignore rules file
.gitattributes          # Git attributes configuration

# Python
__pycache__             # Compiled Python bytecode cache
*.py[cod]               # Compiled Python files (.pyc, .pyo, .pyd)
*.pyo                   # Optimized Python bytecode
.pytest_cache           # Pytest cache directory
.mypy_cache             # MyPy type-checking cache
.ruff_cache             # Ruff linter cache
*.egg-info              # Python package metadata
dist/                   # Distribution/build output
build/                  # Build artifacts

# Virtual environments (recreated inside container by uv)
.venv                   # Local virtual environment
venv/                   # Alternative virtual environment name
env/                    # Another common virtual environment name

# Environment variables (sensitive, must NEVER be included in image)
.env                    # Main environment file
.env.*                  # Other environment variants (e.g., .env.dev)
!.env.example           # Keep example env file (safe template)

# Development tools
.vscode/                # VS Code settings
.idea/                  # JetBrains IDE settings
*.swp                   # Vim swap file
*.swo                   # Vim swap file (alternate)

# Tests
tests/                  # Test directory
test_*                  # Test files (prefix)
*_test.py               # Test files (suffix)

# Documentation
README.md               # Project readme
docs/                   # Documentation folder

# Docker itself
Dockerfile*             # Dockerfiles
docker-compose*.yml     # Docker Compose configs
.dockerignore           # Docker ignore file itself

# Local database files
*.db                    # SQLite / generic DB files
*.sqlite3               # SQLite database files

# Media files (mounted at runtime, not included in image)
# media/                # Uncomment if you want to exclude media files